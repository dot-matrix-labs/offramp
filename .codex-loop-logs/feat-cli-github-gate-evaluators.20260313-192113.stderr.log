+        GithubReviewStatus::ReviewRequired => "review-required",
+        GithubReviewStatus::ChangesRequested => "changes-requested",
+    }
+}
+
+fn github_mergeability_label(status: &GithubMergeability) -> &'static str {
+    match status {
