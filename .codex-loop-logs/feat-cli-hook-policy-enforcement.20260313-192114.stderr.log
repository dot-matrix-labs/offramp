+            .with_main_compatible_root(repo_root);
+
+        let evidence = collect_policy_evidence(&environment, repo_root, &sample_template());
+
+        assert_eq!(
+            evidence.result_for("builtin.policy.implementation_plan_present"),
+            Some(true)
