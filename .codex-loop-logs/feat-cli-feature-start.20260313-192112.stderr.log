+                    println!("Worktree: {}", result.worktree_path.display());
+                    println!(
+                        "Pull request: #{} {}",
+                        result.pull_request.number, result.pull_request.url
+                    );
+                    println!("State: {}", result.state_path.display());
+                }
+                Err(error) => {
+                    eprintln!("feature-start error: {error}");
+                    std::process::exit(1);
+                }
+            }
+        }
         _ => println!("{}", render_help(info)),
     }
 }
