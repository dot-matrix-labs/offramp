+#[test]
+fn feature_state_builds_pull_request_checklist_from_gate_statuses() {
+    let feature = FeatureState {
+        feature_id: "feature".to_string(),
+        branch: "feature".to_string(),
+        worktree_path: "/tmp/feature".to_string(),
+        pull_request: PullRequestRef {
+            number: 7,
+            url: "https://github.com/dot-matrix-labs/calypso/pull/7".to_string(),
+        },
+        workflow_state: WorkflowState::Implementation,
+        gate_groups: vec![GateGroup {
+            id: "policy".to_string(),
+            label: "Policy".to_string(),
+            gates: vec![
+                Gate {
+                    id: "implementation-plan-present".to_string(),
+                    label: "Implementation plan present".to_string(),
+                    task: "implementation-plan-present".to_string(),
+                    status: GateStatus::Passing,
+                },
+                Gate {
+                    id: "next-prompt-present".to_string(),
+                    label: "Next prompt present".to_string(),
+                    task: "next-prompt-present".to_string(),
+                    status: GateStatus::Failing,
+                },
+            ],
+        }],
+        active_sessions: Vec::new(),
+    };
+
+    let checklist = feature.pull_request_checklist();
+
+    assert_eq!(checklist.len(), 2);
+    assert_eq!(checklist[0].gate_id, "implementation-plan-present");
+    assert!(checklist[0].checked);
+    assert_eq!(checklist[1].gate_id, "next-prompt-present");
+    assert!(!checklist[1].checked);
+}
