+        )
+        .map(|_| ())
+    }
+
+    fn remove_branch(&self, repo_root: &Path, branch: &str) -> Result<(), FeatureStartError> {
+        run_git(repo_root, &["branch", "-D", branch]).map(|_| ())
+    }
+}
