+fn make_check(
+    id: DoctorCheckId,
+    scope: DoctorCheckScope,
+    passing: bool,
+    detail: Option<String>,
+) -> DoctorCheck {
+    let status = status_from_bool(passing);
+    let remediation = (status == DoctorStatus::Failing)
+        .then(|| failing_fix(id, detail.as_deref()))
+        .flatten();
+
+    DoctorCheck {
+        id,
+        scope,
+        status,
+        detail,
+        remediation,
+    }
+}
