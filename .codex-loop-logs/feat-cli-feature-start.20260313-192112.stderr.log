+        )
+        .map(|_| ())
+    }
+
+    fn push_branch(&self, worktree_path: &Path, branch: &str) -> Result<(), FeatureStartError> {
+        run_git(worktree_path, &["push", "-u", "origin", branch]).map(|_| ())
+    }
