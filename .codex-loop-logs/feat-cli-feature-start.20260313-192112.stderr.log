+    };
+
+    let error = start_feature(Path::new("."), &sample_request(), &environment)
+        .expect_err("worktree failure should bubble up");
+
+    assert!(matches!(error, FeatureStartError::GitCommandFailed { .. }));
+    assert_eq!(
+        environment.actions.borrow().as_slice(),
