+            "remove-branch:feat/cli-feature-start".to_string(),
+        ]
+    );
+}
+
+#[test]
+fn start_feature_reports_partial_failure_when_pull_request_creation_fails() {
+    let environment = FakeEnvironment {
+        pr_failure: Some("api down".to_string()),
