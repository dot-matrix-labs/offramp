+            self.files.insert(path.to_path_buf());
+            self.modified_times.insert(path.to_path_buf(), modified);
+            self
+        }
+
+        fn with_main_compatible_root(mut self, path: &Path) -> Self {
+            self.main_compatible_roots.insert(path.to_path_buf());
