+        &self,
+        repo_root: &Path,
+        branch: &str,
+    ) -> Result<(), FeatureStartError>;
+    fn create_worktree(
+        &self,
+        repo_root: &Path,
+        branch: &str,
+        worktree_path: &Path,
+    ) -> Result<(), FeatureStartError>;
+    fn push_branch(&self, worktree_path: &Path, branch: &str) -> Result<(), FeatureStartError>;
