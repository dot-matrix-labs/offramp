+    assert!(matches!(error, FeatureStartError::InvalidBaseBranch { .. }));
+    assert!(environment.actions.borrow().is_empty());
+}
+
+#[test]
+fn start_feature_rolls_back_branch_when_worktree_creation_fails() {
