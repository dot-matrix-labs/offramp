+const DEFAULT_BRANCH_PREFIX: &str = "feat";
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct FeatureStartRequest {
+    pub feature_id: String,
+    pub worktree_base: PathBuf,
