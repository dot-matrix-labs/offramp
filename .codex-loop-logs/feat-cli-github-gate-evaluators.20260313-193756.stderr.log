+    assert_eq!(report.snapshot, None);
+    assert_eq!(report.error.as_deref(), Some("Run `gh auth login`."));
+    assert_eq!(
+        report.checks[0].status,
+        EvidenceStatus::Failing,
+        "the missing snapshot should still block the PR existence gate"
+    );
+}
