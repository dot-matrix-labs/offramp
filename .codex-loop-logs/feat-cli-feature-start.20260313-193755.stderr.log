  replaced=false
  new_args=()
  for ((i=0; i<${#args[@]}; i++)); do
    arg=${args[i]}
    if [[ $arg == --emit ]]; then
      new_args+=("--emit" "$link_emit")
      ((i+=1))
      replaced=true
    elif [[ $arg == --emit=* ]]; then
      new_args+=("--emit=$link_emit")
      replaced=true
    else
      new_args+=("$arg")
    fi
  done
  "$real_rustc" "${new_args[@]}"
fi

mkdir -p "$(dirname "$metadata_path")"
meta_args=()
for ((i=0; i<${#args[@]}; i++)); do
  arg=${args[i]}
  if [[ $arg == --emit ]]; then
    meta_args+=("--emit" "metadata=-")
    ((i+=1))
  elif [[ $arg == --emit=* ]]; then
    meta_args+=("--emit=metadata=-")
  elif [[ $arg == -o ]]; then
    ((i+=1))
  else
    meta_args+=("$arg")
  fi
done
"$real_rustc" "${meta_args[@]}" > "$metadata_path"
