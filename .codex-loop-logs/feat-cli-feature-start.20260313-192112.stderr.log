+
+            fs::remove_dir_all(repo_root).expect("repo root should be removed");
+            fs::remove_dir_all(bare_remote).expect("bare remote should be removed");
+            fs::remove_dir_all(worktree_base).expect("worktree base should be removed");
+        },
+    );
+}

