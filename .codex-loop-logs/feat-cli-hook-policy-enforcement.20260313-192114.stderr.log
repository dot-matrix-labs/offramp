+            Some(true)
+        );
+    }
+
+    #[test]
+    fn policy_evidence_fails_when_plan_or_workflows_are_missing_or_stale() {
+        let repo_root = Path::new("/tmp/calypso-policy");
+        let environment = FakePolicyEnvironment::default()
