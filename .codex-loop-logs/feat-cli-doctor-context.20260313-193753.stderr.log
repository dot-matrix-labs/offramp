+    );
+
+    assert_eq!(
+        check_for(&report, DoctorCheckId::GhAuthenticated).scope,
+        DoctorCheckScope::ExternalAuth
+    );
+    assert_eq!(
+        check_for(&report, DoctorCheckId::FeatureBindingResolved).scope,
+        DoctorCheckScope::LocalConfiguration
+    );
+}
