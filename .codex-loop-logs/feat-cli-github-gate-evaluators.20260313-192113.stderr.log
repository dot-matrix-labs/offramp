+        GithubMergeability::Conflicting => "conflicting",
+        GithubMergeability::Blocked => "blocked",
+        GithubMergeability::Unknown => "unknown",
+    }
+}
+
+fn evidence_status_label(status: &EvidenceStatus) -> &'static str {
+    match status {
